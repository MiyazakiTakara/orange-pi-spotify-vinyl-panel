# Runtime user/group are set in systemd unit files.
# Copy this file to /etc/default/spotify-panel and adjust if needed.

SPOTIFY_PANEL_DIR=/opt/spotify-panel
SPOTIFY_PANEL_WEB_DIR=/opt/spotify-panel/web
SPOTIFY_PANEL_STATE=/opt/spotify-panel/state.json
SPOTIFY_PANEL_LAST_GOOD=/opt/spotify-panel/last-good-state.json
SPOTIFY_PANEL_LOCK=/opt/spotify-panel/state.lock
SPOTIFY_PANEL_COVERS=/opt/spotify-panel/covers
SPOTIFY_PANEL_HOST=0.0.0.0
SPOTIFY_PANEL_PORT=8080
SPOTIFY_PANEL_PYTHONPATH=/opt/spotify-panel/src

LIBRESPOT_NAME=Pomaranczowy Streamer
LIBRESPOT_DEVICE=plughw:0,0
LIBRESPOT_BITRATE=320
LIBRESPOT_INITIAL_VOLUME=35
LIBRESPOT_CACHE=/var/cache/librespot
